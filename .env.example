# Ads Automation Platform
# Copy to .env and fill in actual values. NEVER commit .env

# ── Database (Zeabur auto-injects this) ─────────────────────
POSTGRES_CONNECTION_STRING=postgresql://postgres:password@localhost:5432/ads_platform

# ── Redis (Zeabur auto-injects this) ─────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Meta Ads API — Per-branch tokens ────────────────────────
META_ACCESS_TOKEN_SAIGON=your_token_here
META_AD_ACCOUNT_SAIGON=act_XXXXX

META_ACCESS_TOKEN_OANI=your_token_here
META_AD_ACCOUNT_OANI=act_XXXXX

META_ACCESS_TOKEN_OSAKA=your_token_here
META_AD_ACCOUNT_OSAKA=act_XXXXX

META_ACCESS_TOKEN_TAIPEI=your_token_here
META_AD_ACCOUNT_TAIPEI=act_XXXXX

META_ACCESS_TOKEN_1948=your_token_here
META_AD_ACCOUNT_1948=act_XXXXX

# ── Google Ads API (Phase 4) ────────────────────────────────
GOOGLE_DEVELOPER_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_LOGIN_CUSTOMER_ID=

# ── TikTok Ads API (Phase 4) ────────────────────────────────
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=

# ── Claude API (Phase 5) ────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Figma API (Phase 6) ─────────────────────────────────────
FIGMA_ACCESS_TOKEN=
FIGMA_TEAM_ID=

# ── Export API ──────────────────────────────────────────────
EXPORT_API_RATE_LIMIT_DAILY=1000

# ── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-32-char-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── SMTP (Email notifications) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@meander.com
SMTP_PASSWORD=
SMTP_FROM_NAME=Meander Ads Platform

# ── App Config ───────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=info
SYNC_INTERVAL_MINUTES=15

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Cloudbeds PMS — Per-branch Personal API Keys + property IDs ─────
# Create keys in myfrontdesk → Manage → API Credentials (one per property).
CLOUDBEDS_API_BASE_URL=https://hotels.cloudbeds.com/api/v1.2
CB_API_KEY_SAIGON=
CB_PROPERTY_ID_SAIGON=
CB_API_KEY_TAIPEI=
CB_PROPERTY_ID_TAIPEI=
CB_API_KEY_1948=
CB_PROPERTY_ID_1948=
CB_API_KEY_OSAKA=
CB_PROPERTY_ID_OSAKA=
CB_API_KEY_OANI=
CB_PROPERTY_ID_OANI=

# ── Internal scheduled-task secret (Zeabur cron → backend) ─────
INTERNAL_TASK_SECRET=

# ── Microsoft Clarity (Landing Page analytics) ────────────────────
# Get CLARITY_API_TOKEN from Clarity project → Settings → Data Export API.
# Token has scope Data.Export and is typically long-lived (10y+). NEVER commit.
# CLARITY_PROJECT_ID is the numeric tracking id from Clarity's JS snippet —
# same value as the token's `sub` JWT claim.
CLARITY_API_TOKEN=
CLARITY_PROJECT_ID=
